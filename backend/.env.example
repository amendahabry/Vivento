# Copy this file to .env and fill in real values. Never commit .env or google-credentials.json.

# Google Drive (path is relative to backend folder unless absolute)
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id

# AWS S3 (photo uploads)
S3_BUCKET=your-bucket-name
S3_REGION=eu-central-1
S3_ACCESS_KEY_ID=your-aws-access-key-id
S3_SECRET_ACCESS_KEY=your-aws-secret-access-key

# Auth (use a long random string, e.g. openssl rand -hex 32)
JWT_SECRET=your-long-random-secret

# Server
PORT=3000
NODE_ENV=development

# CORS - Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:4200,https://viventoevents.com

# Database path (optional, defaults to backend/Vivento.sqlite3)
DB_PATH=./Vivento.sqlite3

# Optional: Gmail SMTP for contact notifications (use an App Password, not your normal password)
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# Optional: where admin copies of contact notifications go
ADMIN_NOTIFY_EMAIL=admin@example.com

# Optional: WhatsApp queue rows for internal alerts (local format, e.g. 05XXXXXXXX)
ADMIN_NOTIFY_PHONE=05XXXXXXXX
ADMIN_NOTIFY_NAME=Admin

# Optional: WhatsApp JID for wppconnect example bot (country code + number, e.g. 9725XXXXXXXX@c.us)
ADMIN_WHATSAPP_JID=

# Optional: Google AI (Gemini) for wppconnect example
GOOGLE_API_KEY=
